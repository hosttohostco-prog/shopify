{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "display_category": {
          "type": "display_category"
        },
        "title": {
          "type": "title"
        },
        "caption": {
          "type": "text",
          "settings": {
            "text": "{{ product.metafields.descriptors.subtitle.value }}",
            "text_style": "subtitle"
          }
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": false,
            "show_gift_card_recipient": true
          }
        },
        "assurance": {
          "type": "assurance",
          "settings": {
            "assurance_1": "Entrega 24h",
            "assurance_2": "Cambios 30 días"
          }
        },
        "whatsapp_link": {
          "type": "whatsapp_link",
          "settings": {
            "label": "Pedir por WhatsApp"
          }
        },
        "collapsible-row-0": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Materials",
            "icon": "leather",
            "content": "",
            "page": ""
          }
        },
        "collapsible-row-1": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & Returns",
            "icon": "truck",
            "content": "",
            "page": ""
          }
        },
        "collapsible-row-2": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Dimensions",
            "icon": "ruler",
            "content": "",
            "page": ""
          }
        },
        "collapsible-row-3": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Care Instructions",
            "icon": "heart",
            "content": "",
            "page": ""
          }
        }
      },
      "block_order": [
        "display_category",
        "title",
        "caption",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "assurance",
        "whatsapp_link",
        "collapsible-row-0",
        "collapsible-row-1",
        "collapsible-row-2",
        "collapsible-row-3"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "thumbnail",
        "media_size": "large",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "show",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "product-editorial": {
      "type": "product-editorial",
      "settings": {
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "product-trust": {
      "type": "product-trust",
      "blocks": {
        "criterion-1": {
          "type": "criterion",
          "settings": {
            "heading": "Probadas en mis propios Airbnb",
            "body": "Vivieron cientos de rotaciones en mis cuatro propiedades antes de entrar al catálogo. Nada se vende sin esa prueba."
          }
        },
        "criterion-2": {
          "type": "criterion",
          "settings": {
            "heading": "Durabilidad calidad hotelera",
            "body": "Vidrio reforzado que aguanta el lavavajillas a diario sin opacarse, astillarse ni perder el filo del borde."
          }
        },
        "criterion-3": {
          "type": "criterion",
          "settings": {
            "heading": "Disponibles localmente en Colombia",
            "body": "En stock en Medellín. Las ves, las pides y llegan — sin catálogos importados que nunca aterrizan."
          }
        },
        "criterion-4": {
          "type": "criterion",
          "settings": {
            "heading": "Sin demoras de importación",
            "body": "Nada de aduanas ni esperas de semanas. Repones una copa rota el mismo día que la necesitas."
          }
        }
      },
      "block_order": [
        "criterion-1",
        "criterion-2",
        "criterion-3",
        "criterion-4"
      ],
      "settings": {
        "padding_top": 80,
        "padding_bottom": 80
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "products_to_show": 6,
        "padding_top": 60,
        "padding_bottom": 60
      }
    }
  },
  "order": [
    "main",
    "product-editorial",
    "product-trust",
    "related-products"
  ]
}
