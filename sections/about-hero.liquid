{{ 'brand.css' | asset_url | stylesheet_tag }}

{%- style -%}
.abh {
  background: var(--cream);
  overflow: hidden;
}
.abh__inner {
  display: grid;
  grid-template-columns: 35fr 65fr;
  min-height: clamp(800px, 92vh, 960px);
}
.abh__copy-col {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-top: 80px;
  padding-bottom: 56px;
  padding-right: clamp(32px, 4vw, 64px);
  padding-left: max(var(--gutter), calc((100vw - 1280px) / 2 + var(--gutter)));
}
.abh__copy-top {
  display: flex;
  flex-direction: column;
}
.abh__eyebrow {
  font-family: var(--font-label);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--coral-deep);
  margin: 0 0 20px;
}
.abh__heading {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(56px, 7.5vw, 108px);
  letter-spacing: -0.04em;
  line-height: 0.95;
  color: var(--ink);
  margin: 0 0 28px;
  text-wrap: balance;
}
.abh__intro {
  font-size: clamp(15px, 1.15vw, 17px);
  line-height: 1.65;
  color: var(--ink-soft);
  margin: 0 0 32px;
  text-wrap: pretty;
}
.abh__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 28px;
  background: var(--ink);
  color: var(--cream);
  font-family: var(--font-label);
  font-size: 11.5px;
  font-weight: 600;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 100px;
  transition: background 0.2s ease;
  align-self: flex-start;
}
.abh__cta:hover {
  background: var(--ink-70);
}
.abh__creds {
  display: flex;
  border-top: 1px solid var(--ink-40);
  padding-top: 24px;
  gap: 0;
}
.abh__cred {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  padding: 0 10px;
  text-align: center;
  border-right: 1px solid var(--ink-40);
}
.abh__cred:first-child { padding-left: 0; }
.abh__cred:last-child { border-right: none; }
.abh__cred-icon {
  color: var(--coral-deep);
  margin-bottom: 4px;
  flex: none;
}
.abh__cred-stat {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(13px, 1.1vw, 15px);
  letter-spacing: -0.01em;
  line-height: 1.1;
  color: var(--ink);
  margin: 0;
  text-transform: uppercase;
}
.abh__cred-label {
  font-family: var(--font-label);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-soft);
  margin: 0;
  line-height: 1.3;
}
.abh__media-col {
  position: relative;
  overflow: hidden;
}
.abh__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}
.abh__placeholder {
  position: absolute;
  inset: 0;
  background: var(--cream-deep);
  display: flex;
  align-items: center;
  justify-content: center;
}
.abh__placeholder-label {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-40);
}
@media screen and (max-width: 989px) {
  .abh__inner {
    grid-template-columns: 1fr;
    min-height: unset;
  }
  .abh__media-col {
    order: -1;
    height: 420px;
  }
  .abh__copy-col {
    padding: 48px var(--gutter) 52px;
    justify-content: flex-start;
    gap: 0;
  }
  .abh__creds { margin-top: 40px; }
  .abh__intro { max-width: unset; }
}
@media screen and (max-width: 749px) {
  .abh__media-col { height: 320px; }
  .abh__copy-col { padding: 40px 20px 44px; }
  .abh__creds { flex-wrap: wrap; gap: 16px 0; margin-top: 32px; }
  .abh__cred {
    flex: 0 0 50%;
    border-right: none;
    border-bottom: 1px solid var(--ink-40);
    padding: 0 0 16px;
    align-items: flex-start;
    text-align: left;
  }
  .abh__cred:nth-child(3),
  .abh__cred:nth-child(4) { border-bottom: none; }
}
{%- endstyle -%}

<section class="abh">
  <div class="abh__inner">

    <div class="abh__copy-col">
      <div class="abh__copy-top">
        {%- if section.settings.eyebrow != blank -%}
          <p class="abh__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        <h1 class="abh__heading">{{ section.settings.heading | escape }}</h1>

        {%- if section.settings.intro != blank -%}
          <p class="abh__intro">{{ section.settings.intro }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url | default: '/' }}" class="abh__cta">
            {{- section.settings.cta_label -}}
          </a>
        {%- endif -%}
      </div>

      {%- if section.blocks.size > 0 -%}
        <div class="abh__creds">
          {%- for block in section.blocks -%}
            {%- if block.type == 'credential' -%}
              <div class="abh__cred" {{ block.shopify_attributes }}>
                <span class="abh__cred-icon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'star' -%}
                      <svg width="22" height="22" viewBox="0 0 28 28" fill="none"><path d="M14 3l2.96 6.05 6.62.97-4.79 4.69 1.13 6.61L14 18.25l-5.92 3.07 1.13-6.61L4.42 10.02l6.62-.97L14 3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                    {%- when 'key' -%}
                      <svg width="22" height="22" viewBox="0 0 28 28" fill="none"><circle cx="10" cy="11" r="6" stroke="currentColor" stroke-width="1.6"/><path d="M14.5 15l9 9M20 19l2.5 2.5M23.5 22.5l-2 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                    {%- when 'heart' -%}
                      <svg width="22" height="22" viewBox="0 0 28 28" fill="none"><path d="M14 23S4 16.5 4 9.5A5.5 5.5 0 0114 7a5.5 5.5 0 0110 2.5C24 16.5 14 23 14 23z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                    {%- when 'check' -%}
                      <svg width="22" height="22" viewBox="0 0 28 28" fill="none"><polyline points="5,14 11,20 23,8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {%- else -%}
                      <svg width="22" height="22" viewBox="0 0 28 28" fill="none"><path d="M4 12.5L14 4l10 8.5V24a1 1 0 01-1 1H5a1 1 0 01-1-1V12.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M10 25v-9h8v9" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
                  {%- endcase -%}
                </span>
                {%- if block.settings.stat != blank -%}
                  <p class="abh__cred-stat">{{ block.settings.stat }}</p>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <p class="abh__cred-label">{{ block.settings.label }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="abh__media-col">
      {%- if section.settings.image != blank -%}
        {%- assign abh_alt = section.settings.image_alt | default: section.settings.heading | escape -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            class: 'abh__img',
            loading: 'eager',
            fetchpriority: 'high',
            alt: abh_alt,
            widths: '700, 900, 1100, 1400'
        }}
      {%- else -%}
        {%- assign abh_alt = section.settings.image_alt | default: section.settings.heading | escape -%}
        <img
          class="abh__img"
          src="{{ 'about-hero.png' | asset_url }}"
          alt="{{ abh_alt }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "About — Hero",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "credential",
      "name": "Credencial",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            { "value": "home",  "label": "Casa" },
            { "value": "star",  "label": "Estrella" },
            { "value": "key",   "label": "Llave" },
            { "value": "heart", "label": "Corazón" },
            { "value": "check", "label": "Check" }
          ],
          "default": "home"
        },
        {
          "type": "text",
          "id": "stat",
          "label": "Dato principal",
          "default": "9 años"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiqueta",
          "default": "Hospedando"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Antetítulo",
      "default": "Superhost · Medellín · 9 años hospedando"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Sobre Mafe"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Introducción",
      "default": "Empecé hospedando en Medellín hace nueve años. Lo que tienes aquí son los productos que sobrevivieron cientos de rotaciones en mis propias propiedades — nada más."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texto del botón CTA",
      "default": "Conoce la colección"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Enlace del botón CTA"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Foto (retrato o lifestyle)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texto alternativo de la imagen"
    }
  ],
  "presets": [
    {
      "name": "About — Hero",
      "blocks": [
        { "type": "credential", "settings": { "icon": "home",  "stat": "9 años",        "label": "Hospedando" } },
        { "type": "credential", "settings": { "icon": "star",  "stat": "Superhost",     "label": "Airbnb" } },
        { "type": "credential", "settings": { "icon": "key",   "stat": "4+",            "label": "Propiedades" } },
        { "type": "credential", "settings": { "icon": "heart", "stat": "Selección",     "label": "Personal" } }
      ]
    }
  ]
}
{% endschema %}
