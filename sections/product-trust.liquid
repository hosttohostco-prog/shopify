{{ 'brand.css' | asset_url | stylesheet_tag }}

<section class="pdp-trust section-{{ section.id }}-padding">
  <div class="page-width">

    <div class="pdp-trust-head">
      <p class="pdp-trust-eyebrow">Por qué entraron a la colección</p>
      <h2 class="pdp-trust-title">No es un producto que encontré. <em>Es uno que ya repongo.</em></h2>
    </div>

    {%- if section.blocks.size > 0 -%}
    <div class="pdp-trust-list pdp-trust-list--{{ section.blocks.size }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'criterion' -%}
        <div class="pdp-criterion" {{ block.shopify_attributes }}>
          <span class="pdp-cr-check" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
              <polyline points="4,11 9,16 18,6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <h3 class="pdp-cr-h">{{ block.settings.heading }}</h3>
          <p class="pdp-cr-b">{{ block.settings.body }}</p>
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- endif -%}

  </div>
</section>

{%- style -%}
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}
@media screen and (max-width: 749px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round }}px;
  }
}
{%- endstyle -%}

{% schema %}
{
  "name": "Trust Layer",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "criterion",
      "name": "Criterion",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Probadas en propiedades reales"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body",
          "default": "Descripción del criterio."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Trust Layer",
      "blocks": [
        {
          "type": "criterion",
          "settings": {
            "heading": "Probadas en mis propios Airbnb",
            "body": "Vivieron cientos de rotaciones en mis cuatro propiedades antes de entrar al catálogo. Nada se vende sin esa prueba."
          }
        },
        {
          "type": "criterion",
          "settings": {
            "heading": "Durabilidad calidad hotelera",
            "body": "Vidrio reforzado que aguanta el lavavajillas a diario sin opacarse, astillarse ni perder el filo del borde."
          }
        },
        {
          "type": "criterion",
          "settings": {
            "heading": "Disponibles localmente en Colombia",
            "body": "En stock en Medellín. Las ves, las pides y llegan — sin catálogos importados que nunca aterrizan."
          }
        },
        {
          "type": "criterion",
          "settings": {
            "heading": "Sin demoras de importación",
            "body": "Nada de aduanas ni esperas de semanas. Repones una copa rota el mismo día que la necesitas."
          }
        }
      ]
    }
  ]
}
{% endschema %}
