{%- comment -%}
  HostToHost — Manifesto strip (bespoke)
  Phase 2 · Step G. A single editorial line that states the brand's point of
  view, per the design handoff + CLAUDE-DESIGN-BRIEF §5.1. Fraunces display
  quote (italic word in coral via inline_richtext <em>) + Caveat script
  attribution. Self-contained: layout/type live in this section's own
  {% stylesheet %} block on brand tokens from brand.css :root. Per-section
  padding via Dawn's {% style %}+section.id idiom (same as hero.liquid).
{%- endcomment -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.7 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="brand-manifesto brand-manifesto--{{ section.settings.background }} section-{{ section.id }}-padding">
  <div class="brand-manifesto__wrap">
    {%- if section.settings.quote != blank -%}
      <blockquote class="brand-manifesto__quote">{{ section.settings.quote }}</blockquote>
    {%- endif -%}
    {%- if section.settings.attribution != blank -%}
      <cite class="brand-manifesto__cite">{{ section.settings.attribution }}</cite>
    {%- endif -%}
  </div>
</div>

{%- stylesheet -%}
  .brand-manifesto--cream { background: var(--cream); }
  .brand-manifesto--white { background: #fff; }
  .brand-manifesto--sage { background: var(--sage-soft); }
  .brand-manifesto--ink { background: var(--ink); color: var(--cream); }

  .brand-manifesto__wrap {
    max-width: var(--hth-maxw);
    margin-inline: auto;
    padding-inline: var(--hth-gutter);
    text-align: center;
  }

  .brand-manifesto__quote {
    margin: 0;
    max-width: 22ch;
    margin-inline: auto;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    line-height: 1.12;
    letter-spacing: -0.01em;
    font-size: clamp(1.9rem, 4.6vw, 3.4rem);
    text-wrap: balance;
    color: inherit;
  }
  .brand-manifesto__quote em,
  .brand-manifesto__quote i {
    font-style: italic;
    color: var(--coral);
  }

  .brand-manifesto__cite {
    display: block;
    margin-top: 1.25rem;
    font-family: var(--script);
    font-style: normal;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--sage);
  }
  .brand-manifesto--ink .brand-manifesto__cite { color: var(--peach); }
{%- endstylesheet -%}

{% schema %}
{
  "name": "Manifiesto",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Fondo",
      "options": [
        { "value": "cream", "label": "Crema" },
        { "value": "white", "label": "Blanco" },
        { "value": "sage", "label": "Verde salvia" },
        { "value": "ink", "label": "Tinta (oscuro)" }
      ],
      "default": "cream"
    },
    {
      "type": "inline_richtext",
      "id": "quote",
      "label": "Frase",
      "info": "Usa cursiva para resaltar una palabra en coral.",
      "default": "Un espacio bonito y un espacio que funciona no son lo mismo."
    },
    {
      "type": "text",
      "id": "attribution",
      "label": "Firma",
      "default": "— Mafe"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "label": "Espacio superior",
      "default": 88
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "label": "Espacio inferior",
      "default": 88
    }
  ],
  "presets": [
    {
      "name": "Manifiesto"
    }
  ]
}
{% endschema %}
